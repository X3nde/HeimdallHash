                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Nombre del servicio:"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ServiceNameBox"/>
                                <Label Grid.Row="1" Grid.Column="0" Content="Nombre visible:"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ServiceDisplayNameBox"/>
                                <Label Grid.Row="2" Grid.Column="0" Content="Ruta ejecutable:"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="ServiceExecutablePathBox"/>
                                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource BotonRutaEstilo}" Content="..." Click="SeleccionarEjecutableServicio_Click"/>

                                <Label Grid.Row="3" Grid.Column="0" Content="Tipo de inicio:"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ServiceStartTypeCombo">
                                    <ComboBoxItem Content="Automático"/>
                                    <ComboBoxItem Content="Manual"/>
                                </ComboBox>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="InstalarServicioButton" Style="{StaticResource BotonPrimario}" Content="Instalar servicio" Click="InstalarServicio_Click"/>
                                    <Button x:Name="DesinstalarServicioButton" Style="{StaticResource BotonEstilo}" Content="Desinstalar servicio" Click="DesinstalarServicio_Click"/>
                                    <Button x:Name="IniciarServicioButton" Style="{StaticResource BotonEstilo}" Content="Iniciar" Click="IniciarServicio_Click"/>
                                    <Button x:Name="DetenerServicioButton" Style="{StaticResource BotonEstilo}" Content="Detener" Click="DetenerServicio_Click"/>
                                    <Button x:Name="ReiniciarServicioButton" Style="{StaticResource BotonEstilo}" Content="Reiniciar" Click="ReiniciarServicio_Click"/>
                                    <Button Style="{StaticResource BotonEstilo}" Content="Actualizar estado" Click="ActualizarEstado_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Style="{StaticResource PestanaHeimdallStyle}" Header="Validar configuración">
                <DockPanel Margin="14" MaxWidth="1450" HorizontalAlignment="Center">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                        <Button Style="{StaticResource BotonPrimario}" Content="Ejecutar validación" Click="Validar_Click"/>
                        <Button Style="{StaticResource BotonEstilo}" Content="Crear directorios internos" Click="CrearDirectorios_Click"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="La validación muestra errores bloqueantes y advertencias antes de guardar o poner en servicio la aplicación." Foreground="{StaticResource TextoSuave}" Margin="4,4,4,8"/>
                    <DataGrid x:Name="ValidacionGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MaxWidth="1400" HorizontalAlignment="Stretch">
                        <DataGrid.Columns>
                            <DataGridTextColumn ElementStyle="{StaticResource DataGridTextBlockStyle}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Nivel" Binding="{Binding Nivel}" Width="120"/>
                            <DataGridTextColumn ElementStyle="{StaticResource DataGridTextBlockStyle}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Mensaje" Binding="{Binding Mensaje}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3" x:Name="StatusBarText" Text="Listo." Foreground="{StaticResource TextoSuave}" Margin="4,8,4,0"/>
    </Grid>
</Window>
